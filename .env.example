# Server
SERVER_PORT=8080

# n8n
N8N_WEBHOOK_BASE_URL=http://n8n:5678

# Alexa
ALEXA_SKILL_ID=amzn1.ask.skill.xxxxx
ALEXA_VERIFY_REQUESTS=false

# Default n8n agent path for unmatched intents
DEFAULT_AGENT=general-assistant

# Intent-to-agent mapping (JSON object: intent_name -> agent_path)
INTENT_AGENT_MAP={"AskQuestionIntent":"general-assistant","SmartHomeIntent":"smart-home"}

# Groq (free tier: https://console.groq.com)
GROQ_API_KEY=__GROQ_KEY__

# n8n configuration
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
N8N_ENCRYPTION_KEY=change-this-to-a-random-string

# Postgres
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n_password
POSTGRES_DB=n8n
# (POSTGRES_HOST and POSTGRES_PORT are set automatically in docker-compose)
